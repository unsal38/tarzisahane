<div id="product" class="container-fluid pt-5">
    <div class="text-center mb-4">
        <h2 class="section-title px-5"><span class="px-2 text-capitalize">Ürünler</span></h2>
    </div>
    <div class="row px-xl-5 pb-3">
        <% shopi_product_data.forEach(v_product=> {%>
            <% let media=v_product.media %>
                <div class="col-lg-3 col-md-6 col-sm-12 pb-1">
                    <div data-kategori="<%= v_product.categories[0].id _%>" class="card product-item border-0 mb-4">

                        <div
                            class="card-header product-img position-relative overflow-hidden bg-transparent border p-0">
                            <div id="carousel<%= v_product.id _%>" class="carousel slide" data-ride="carousel">
                                <div class="carousel-inner">
                                    <% media.forEach((v_media)=> { %>

                                        <div class="carousel-item">
                                            <img class="d-block img-fluid w-100" data-src="<%= v_media.url %>"
                                                alt="product image">
                                        </div>
                                        <% }); %>

                                </div>
                                <a class="carousel-control-prev" href="#carousel<%= v_product.id _%>" role="button"
                                    data-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="sr-only">Previous</span>
                                </a>
                                <a class="carousel-control-next" href="#carousel<%= v_product.id _%>" role="button"
                                    data-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="sr-only">Next</span>
                                </a>
                            </div>
                        </div>
                        <div class="card-body border-left border-right text-center p-0 pt-4 pb-3">
                            <h6 class="text-truncate mb-3">
                                <%= v_product.title _%>
                            </h6>
                            <div class="d-flex justify-content-center">
                                <h6>
                                    <%= v_product.priceData.currency _%>
                                        <%= v_product.priceData.price _%>
                                </h6>
                                <!-- <h6 class="text-muted ml-2"><del><%= v_product.priceData.currency _%><%= v_product.priceData.discountedPrice _%></del></h6> -->
                            </div>
                        </div>
                        <div class="card-footer d-flex justify-content-between bg-light border">
                            <a target="_blank" href="https://www.shopier.com/creo3dlife/<%= v_product.id _%>"
                                class="btn btn-sm text-dark p-0"><i class="fas fa-eye text-primary mr-1"></i>Detayları
                                gör</a>
                            <a target="_blank" href="https://www.shopier.com/creo3dlife/<%= v_product.id _%>"
                                class="btn btn-sm text-dark p-0"><i
                                    class="fas fa-shopping-cart text-primary mr-1"></i>Satınal</a>
                        </div>
                    </div>
                </div>

                <% }); %>
                    <div class="back-to-up-div">
                        <hr class="back-to-up-hr">
                        <button name="back-to-up" type="button" class="btn btn-primary back-to-up"><i
                                class="fa fa-angle-double-down"></i></button>
                    </div>
    </div>
</div>